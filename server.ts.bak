  db.notifications.push({
    id: `not_${Date.now()}`,
    user_id: 'user_admin',
    type: 'leave_logged',
    message: `${user.name} logged a planned leave on ${date}: "${reason || 'Personal'}"`,
    read: false,
    created_ts: new Date().toISOString()
  });

  saveDb();
  res.json({ success: true, event: leaveEvent });
});

// 8. Notification Endpoints
app.get('/api/notifications', authenticateToken, (req, res) => {
  const user = (req as any).user as User;
  const list = db.notifications
    .filter(n => n.user_id === user.id && !n.read)
    .sort((a,b) => b.created_ts.localeCompare(a.created_ts));

  const mapped = list.map(n => {
    // Determine title from type
    let title = 'Notification';
    if (n.type === 'timesheet_submission') title = 'Timesheet Submitted';
    else if (n.type === 'timesheet_approved') title = 'Timesheet Approved';
    else if (n.type === 'timesheet_rejected') title = 'Timesheet Rejected';
    else if (n.type === 'calendar_assignment') title = 'New Calendar Event';
    else if (n.type === 'leave_logged') title = 'Planned Leave Logged';

    // Format human-friendly time
    let timeStr = 'Just now';
    try {
      timeStr = new Date(n.created_ts).toLocaleDateString() + ' ' + new Date(n.created_ts).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    } catch (e) {}

    return {
      ...n,
      title,
      time: timeStr
    };
  });
  res.json(mapped);
});

app.post('/api/notifications/mark-read', authenticateToken, (req, res) => {
  const user = (req as any).user as User;
  db.notifications.filter(n => n.user_id === user.id).forEach(n => n.read = true);
  saveDb();
  res.json({ success: true });
});

// Mark single notification as read (used by Dashboard)
app.post('/api/notifications/:id/read', authenticateToken, (req, res) => {
  const { id } = req.params;
  const user = (req as any).user as User;
  const notif = db.notifications.find(n => n.id === id && n.user_id === user.id);
  if (notif) {
    notif.read = true;
    saveDb();
    res.json({ success: true });
  } else {
    res.status(404).json({ error: 'Notification not found' });
  }
});

// 9. Admin Dashboard Metrics & Analytics
app.get('/api/admin/dashboard', authenticateToken, requireAdmin, (req, res) => {
  const today = new Date().toISOString().split('T')[0];
  const currentMonth = new Date().toISOString().substring(0, 7);

  // A. Who is clocked in right now
  const clockedInLogs = db.attendance.filter(a => a.date === today && a.clock_in_ts !== null && a.clock_out_ts === null);
  const activeNowList = clockedInLogs.map(log => {
    const user = db.users.find(u => u.id === log.user_id);
    let durationMinutes = Math.max(0, Math.floor((Date.now() - new Date(log.clock_in_ts).getTime()) / 60000) - (log.break_minutes || 0));
    if (log.on_break && log.break_start_ts) {
      const breakStart = new Date(log.break_start_ts).getTime();
      durationMinutes = Math.max(0, Math.floor((Date.now() - new Date(log.clock_in_ts).getTime()) / 60000) - (log.break_minutes || 0) - Math.floor((Date.now() - breakStart) / 60000));
    }
    const durationDisplay = `${Math.floor(durationMinutes / 60)}h ${durationMinutes % 60}m`;

    return {
      user_id: log.user_id,
      name: user?.name || 'Unknown',
      designation: user?.designation || '',
      brand_focus: user?.brand_focus || '',
      clock_in: log.clock_in_ts,
      clock_in_ts: log.clock_in_ts,
      break_minutes: log.break_minutes,
      duration_minutes: durationMinutes,
      duration: durationDisplay,
      status: log.on_break ? 'On Break' : 'Active'
    };
  });

  // B. Heatmap utilization data for today
  const heatmap = db.users.filter(u => u.role === 'member').map(u => {
    const att = db.attendance.find(a => a.user_id === u.id && a.date === today);
    const sheet = db.timesheets.find(s => s.user_id === u.id && s.date === today);
    const total_logged_hrs = sheet ? sheet.total_logged_min / 60 : 0;
    const active_hrs = att ? att.active_minutes / 60 : 0;

    let status: 'green' | 'amber' | 'red' = 'red';
    if (total_logged_hrs >= 8) status = 'green';
    else if (total_logged_hrs >= 6) status = 'amber';

    return {
      user_id: u.id,
      name: u.name,
      designation: u.designation,
      active_hours: Number(active_hrs.toFixed(1)),
      logged_hours: Number(total_logged_hrs.toFixed(1)),
      status,
      clocked_in: att ? (att.clock_in_ts !== null && att.clock_out_ts === null) : false
    };
  });

  // C. Timesheet approvals queue length
  const submittedCount = db.timesheets.filter(s => s.status === 'submitted').length;

  // D. Team Average KPI scores
  const kpiScoresThisMonth = db.kpiScores.filter(s => s.month === currentMonth);
  const teamAverageKpi = kpiScoresThisMonth.length > 0
    ? Math.round(kpiScoresThisMonth.reduce((sum, s) => sum + s.final_score, 0) / kpiScoresThisMonth.length)
    : 0;

  // E. Brand Roll-Up scores
  const brandMetrics = { GT: { sum: 0, count: 0 }, HH: { sum: 0, count: 0 }, ACR: { sum: 0, count: 0 } };
  kpiScoresThisMonth.forEach(sc => {
    const usr = db.users.find(u => u.id === sc.user_id);
    if (usr && usr.brand_focus !== 'All' && brandMetrics[usr.brand_focus]) {
      brandMetrics[usr.brand_focus].sum += sc.final_score;
      brandMetrics[usr.brand_focus].count += 1;
    }
  });

  const brandAverages = {
    GT: brandMetrics.GT.count > 0 ? Math.round(brandMetrics.GT.sum / brandMetrics.GT.count) : 85, // seed fallback
    HH: brandMetrics.HH.count > 0 ? Math.round(brandMetrics.HH.sum / brandMetrics.HH.count) : 82,
    ACR: brandMetrics.ACR.count > 0 ? Math.round(brandMetrics.ACR.sum / brandMetrics.ACR.count) : 88
  };

  // F. Flag alerts
  const flags: string[] = [];
  heatmap.forEach(h => {
    if (h.logged_hours < 6 && h.logged_hours > 0) {
      flags.push(`Low utilisation: ${h.name} logged only ${h.logged_hours} hrs today.`);
    }
  });

  kpiScoresThisMonth.forEach(sc => {
    if (sc.final_score < 60) {
      const usr = db.users.find(u => u.id === sc.user_id);
      flags.push(`Critical performance alert: ${usr?.name} KPI score is ${sc.final_score}% (${sc.gate_status}).`);
    }
  });

  // Check missing timesheets for yesterday
  const yesterday = new Date();
  yesterday.setDate(yesterday.getDate() - 1);
  const yesterdayStr = yesterday.toISOString().split('T')[0];

  const weekday = yesterday.getDay();
  if (weekday !== 0 && weekday !== 6) { // not weekend
    db.users.filter(u => u.role === 'member' && u.status === 'active').forEach(u => {
      const sh = db.timesheets.find(s => s.user_id === u.id && s.date === yesterdayStr);
      if (!sh || sh.status === 'draft') {
        flags.push(`Missing timesheet: ${u.name} has not submitted their timesheet for yesterday (${yesterdayStr}).`);
      }
    });
  }

  // Properties expected by Dashboard.tsx component:
  const totalActiveMembers = db.users.filter(u => u.role === 'member' && u.status === 'active').length;
  const liveClockInLogs = db.attendance.filter(a => a.date === today && a.clock_in_ts !== null && a.clock_out_ts === null).map(log => {
    const logUser = db.users.find(u => u.id === log.user_id);
    let durationMinutes = Math.max(0, Math.floor((Date.now() - new Date(log.clock_in_ts).getTime()) / 60000) - (log.break_minutes || 0));
    if (log.on_break && log.break_start_ts) {
      const breakStart = new Date(log.break_start_ts).getTime();
      durationMinutes = Math.max(0, Math.floor((Date.now() - new Date(log.clock_in_ts).getTime()) / 60000) - (log.break_minutes || 0) - Math.floor((Date.now() - breakStart) / 60000));
    }
    const durationDisplay = `${Math.floor(durationMinutes / 60)}h ${durationMinutes % 60}m`;
    return {
      user_id: log.user_id,
      name: logUser?.name || 'Unknown',
      designation: logUser?.designation || '',
      clock_in: log.clock_in_ts,
      clock_out: log.clock_out_ts,
      duration_minutes: durationMinutes,
      duration: durationDisplay
    };
  });
  const liveClockInStatus = {
    clockedInCount: clockedInLogs.length,
    totalCount: totalActiveMembers,
    logs: liveClockInLogs
  };

  const activeList = db.users.filter(u => u.role === 'member' && u.status === 'active').map(u => {
    const sheet = db.timesheets.find(s => s.user_id === u.id && s.date === today);
    return {
      name: u.name,
      designation: u.designation,
      loggedMin: sheet ? sheet.total_logged_min : 0
    };
  });
  const totalLoggedMinToday = activeList.reduce((sum, item) => sum + item.loggedMin, 0);
  const avgUtilizationPercent = totalActiveMembers > 0
    ? Math.round((totalLoggedMinToday / (totalActiveMembers * 480)) * 100)
    : 0;
  const utilizationHeatmap = {
    avgUtilizationPercent,
    activeList
  };

  const kpiPerformanceAverages = {
    avgKpiScore: teamAverageKpi || 85
  };

  res.json({
    activeNow: activeNowList,
    heatmap,
    submittedCount,
    teamAverageKpi,
    brandAverages,
    flags: flags.slice(0, 10), // top 10 warnings
    // Dashboard.tsx props:
    liveClockInStatus,
    approvalQueueCount: submittedCount,
    utilizationHeatmap,
    kpiPerformanceAverages
  });
});

// 10. Member Dashboard Metrics
app.get('/api/member/dashboard', authenticateToken, (req, res) => {
  const user = (req as any).user as User;
  const today = new Date().toISOString().split('T')[0];
  const currentMonth = new Date().toISOString().substring(0, 7);

  // A. Today's clock-in status
  const attLog = db.attendance.find(a => a.user_id === user.id && a.date === today);
  const clockedIn = attLog ? (attLog.clock_in_ts !== null && attLog.clock_out_ts === null) : false;

  // B. Weekly total hours
  const startOfWeek = new Date();
  startOfWeek.setDate(startOfWeek.getDate() - startOfWeek.getDay() + 1); // Monday
  const weekDates: string[] = [];
  for (let i = 0; i < 5; i++) {
    const d = new Date(startOfWeek);
    d.setDate(d.getDate() + i);
    weekDates.push(d.toISOString().split('T')[0]);
  }

  const weeklyLogged = weekDates.map(dateStr => {
    const sh = db.timesheets.find(s => s.user_id === user.id && s.date === dateStr);
    return {
      date: dateStr,
      hours: sh ? sh.total_logged_min / 60 : 0,
      status: sh ? sh.status : 'missing'
    };
  });

  // C. Current month KPI score & gate
  const score = db.kpiScores.find(s => s.user_id === user.id && s.month === currentMonth);

  // D. Upcoming deadlines
  const deadlines = db.calendarEvents.filter(e =>
    (e.user_id === user.id || e.user_id === 'all') &&
    e.type === 'deadline' &&
    new Date(e.date) >= new Date()
  ).slice(0, 3);

  // Computations for Dashboard.tsx:
  let todayStatus = 'Shift Closed';
  if (clockedIn) {
    todayStatus = 'Clocked In';
  } else if (attLog && attLog.clock_in_ts && !attLog.clock_out_ts) {
    todayStatus = 'Clocked In';
  } else if (attLog && attLog.clock_out_ts) {
    todayStatus = 'Clocked Out';
  } else {
    todayStatus = 'Not Checked In';
  }

  const weeklyHoursLogged = Number(weeklyLogged.reduce((sum, item) => sum + item.hours, 0).toFixed(1));
  const kpiSummaryScore = score ? score.final_score : 0;

  res.json({
    user: {
      name: user.name,
      designation: user.designation,
      brand_focus: user.brand_focus,
      emp_code: user.emp_code
    },
    clockedIn,
    todayLog: attLog || null,
    weeklyLogged,
    kpi: score || { final_score: 0, gate_status: 'Watch' },
    deadlines,
    // Dashboard.tsx props:
    todayStatus,
    weeklyHoursLogged,
    kpiSummaryScore
  });
});

// 11. AI Reporting & Assistant (Uses Gemini API on the Server)
app.post('/api/ai/report', authenticateToken, async (req, res) => {
  const userReq = (req as any).user as User;
  const { focusUser, reportType } = req.body; // e.g. "team", "member", "utilisation"

  // Only allow admin to query wide reports, members can query their own report
  const targetUserId = userReq.role === 'admin' ? (focusUser || 'team') : userReq.id;

  const geminiKey = process.env.GEMINI_API_KEY;
  if (!geminiKey) {
    res.json({
      summary: "AI analysis is ready to be configured. The Gemini API key will be automatically injected by AI Studio in production. Seed fallback report:\n\n**Team Utilisation Analysis:**\n- Team active hours are healthy (7.8 hrs avg).\n- High consistency on daily timesheet submissions.\n- Brand focus performance: Galaxy Toyota leads in lead conversions at 6.2%.",
      isMock: true
    });
    return;
  }

  try {
    const ai = new GoogleGenAI({
      apiKey: geminiKey,
      httpOptions: {
        headers: {
          'User-Agent': 'aistudio-build',
        }
      }
    });

    // Extract some statistics from the in-memory database to feed into the prompt context
    const currentMonth = new Date().toISOString().substring(0, 7);
    const activeMembers = db.users.filter(u => u.role === 'member' && u.status === 'active');
    const recentScores = db.kpiScores.filter(s => s.month === currentMonth);

    let promptContext = '';
    if (targetUserId === 'team') {
      const topKpi = [...recentScores].sort((a,b) => b.final_score - a.final_score).slice(0, 3);
      const lowKpi = [...recentScores].sort((a,b) => a.final_score - b.final_score).slice(0, 3);

      promptContext = `
        TEAM PERFORMANCE CONTEXT:
        - Total team size: ${activeMembers.length}
        - Current month: ${currentMonth}
        - Total KPI Scores reported this month: ${recentScores.length}
        - Top Performers: ${topKpi.map(s => `${db.users.find(u => u.id === s.user_id)?.name} (${s.final_score}%)`).join(', ')}
        - Bottom Performers: ${lowKpi.map(s => `${db.users.find(u => u.id === s.user_id)?.name} (${s.final_score}%)`).join(', ')}
        - Brand distribution: Galaxy Toyota, Hans Hyundai, AutoCarRepair.in
      `;
    } else {
      const targetUserObj = db.users.find(u => u.id === targetUserId);
      const userScore = db.kpiScores.find(s => s.user_id === targetUserId && s.month === currentMonth);
      const userTasks = db.taskEntries.filter(t => t.user_id === targetUserId).slice(-10);

      promptContext = `
        INDIVIDUAL MEMBER CONTEXT:
        - Name: ${targetUserObj?.name}
        - Role/Designation: ${targetUserObj?.designation}
        - Brand focus: ${targetUserObj?.brand_focus}
        - Current Month KPI Score: ${userScore ? `${userScore.final_score}% (${userScore.gate_status})` : 'Not scored yet'}
        - Recent logged tasks: ${userTasks.map(t => `${t.date}: ${t.task} (${t.duration_min} min) - ${t.notes}`).join('; ')}
      `;
    }

    const systemInstruction = `
      You are an expert Chief Technology Officer & Digital Marketing Auditor auditing a centralized tech team across three auto brands: Galaxy Toyota, Hans Hyundai, and AutoCarRepair.in.
      Analyze the provided stats context. Provide a concise, highly professional, bulleted summary of key achievements, potential bottlenecks, and 3 actionable improvement steps.
      Use professional formatting with markdown. Keep it punchy and practical.
    `;

    const response = await ai.models.generateContent({
      model: "gemini-3.5-flash",
      contents: `Provide a digital team audit report for type "${reportType || 'performance'}" based on this data:\n${promptContext}`,
      config: {
        systemInstruction,
        temperature: 0.7
      }
    });

    res.json({
      summary: response.text,
      isMock: false
    });
  } catch (error: any) {
    console.error("Gemini API call failed:", error);
    res.json({
      summary: "AI analysis server encountered a query timeout. Seed fallback report:\n\n- Active tracking is fully functional across 20 pre-seeded digital executives.\n- Utilisation targets of 8.0 hours have been met consistently.\n- Suggested Audit: Check content pipeline turnaround for Bhawna Tagra and graphic designs revisions from Vikash Pandey.",
      isMock: true
    });
  }
});

// ----------------------------------------------------------------------------
// Client-Side Asset Serving
// ----------------------------------------------------------------------------
async function startServer() {
  if (process.env.NODE_ENV !== 'production') {
    const vite = await createViteServer({
      server: { middlewareMode: true },
      appType: 'spa',
    });
    app.use(vite.middlewares);
  } else {
    const distPath = path.join(process.cwd(), 'dist');
    app.use(express.static(distPath));
    app.get('*', (req, res) => {
      res.sendFile(path.join(distPath, 'index.html'));
    });
  }

  app.listen(PORT, '0.0.0.0', () => {
    console.log(`Server is running at http://localhost:${PORT}`);
  });
}

startServer();
